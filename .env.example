# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- Google / Gmail ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080
GMAIL_ADDRESS=your@gmail.com

# --- Spotify ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback
SPOTIFY_USERNAME=

# --- YouTube / Google ---
YOUTUBE_API_KEY=
# (reuses Google OAuth above for authenticated requests)

# --- Finance ---
# Plaid (for bank account aggregation)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox   # sandbox | development | production

# Crypto (CoinGecko is free, no key needed; add others as needed)
COINGECKO_API_KEY=

# --- Chrome / Browser ---
CHROME_PROFILE_DIR=~/Library/Application Support/Google/Chrome
