# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- Google / Gmail ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080
GMAIL_ADDRESS=your@gmail.com

# --- Spotify ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback
SPOTIFY_USERNAME=

# --- YouTube / Google ---
YOUTUBE_API_KEY=
# (reuses Google OAuth above for authenticated requests)

# --- Finance ---
# Plaid (for bank account aggregation)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox   # sandbox | development | production

# Crypto (CoinGecko is free, no key needed; add others as needed)
COINGECKO_API_KEY=

# --- Chrome / Browser ---
CHROME_PROFILE_DIR=~/Library/Application Support/Google/Chrome

# --- VK Video ---
# Get a long-lived token via Kate Mobile's official client app (legacy implicit
# flow; self-registered VK apps return Security Error in 2026).
# Sign in at https://vk.com first, then in the same browser visit:
# https://oauth.vk.com/authorize?client_id=2685278&scope=offline,video,wall,friends&redirect_uri=https://oauth.vk.com/blank.html&display=mobile&response_type=token&revoke=1&v=5.199
# Click Allow. The redirect URL contains #access_token=vk1.a.XXXXX&expires_in=0&...
# Copy the token (offline scope = never expires).
VK_ACCESS_TOKEN=
