{% comment %}
  Free Shipping Progress Bar — Shows how close the customer is to free shipping.
  Include in cart template: {% render 'free-shipping-bar' %}
  Configure threshold below.
{% endcomment %}

{%- assign free_shipping_threshold = 4900 -%}  {% comment %} $49.00 in cents {% endcomment %}
{%- assign cart_total = cart.total_price -%}
{%- assign remaining = free_shipping_threshold | minus: cart_total -%}
{%- assign progress_pct = cart_total | times: 100 | divided_by: free_shipping_threshold -%}
{%- if progress_pct > 100 -%}
  {%- assign progress_pct = 100 -%}
{%- endif -%}

<div class="free-shipping-bar" role="status" aria-live="polite">
  {% if remaining <= 0 %}
    <div class="free-shipping-bar__message free-shipping-bar__message--achieved">
      🎉 You've unlocked <strong>FREE shipping!</strong>
    </div>
    <div class="free-shipping-bar__track">
      <div class="free-shipping-bar__fill free-shipping-bar__fill--complete" style="width: 100%"></div>
    </div>
  {% else %}
    <div class="free-shipping-bar__message">
      You're <strong>{{ remaining | money }}</strong> away from <strong>FREE shipping!</strong>
    </div>
    <div class="free-shipping-bar__track">
      <div class="free-shipping-bar__fill" style="width: {{ progress_pct }}%"></div>
    </div>
  {% endif %}
</div>

<style>
  .free-shipping-bar {
    padding: 12px 16px;
    text-align: center;
    margin-bottom: 16px;
  }

  .free-shipping-bar__message {
    font-size: 14px;
    margin-bottom: 8px;
    color: var(--color-foreground);
  }

  .free-shipping-bar__message--achieved {
    color: #16a34a;
    font-weight: 500;
  }

  .free-shipping-bar__track {
    height: 8px;
    background-color: #e5e7eb;
    border-radius: 4px;
    overflow: hidden;
    max-width: 400px;
    margin: 0 auto;
  }

  .free-shipping-bar__fill {
    height: 100%;
    background: linear-gradient(90deg, #E94560, #ff6b81);
    border-radius: 4px;
    transition: width 0.4s ease;
  }

  .free-shipping-bar__fill--complete {
    background: linear-gradient(90deg, #16a34a, #22c55e);
  }
</style>
