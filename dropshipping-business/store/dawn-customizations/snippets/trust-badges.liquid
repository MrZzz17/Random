{% comment %}
  Trust Badges — Display trust signals on product pages and cart.
  Include with: {% render 'trust-badges' %}
  Optional: {% render 'trust-badges', style: 'compact' %}
{% endcomment %}

{%- assign badge_style = style | default: 'full' -%}

<div class="trust-badges trust-badges--{{ badge_style }}" role="complementary" aria-label="Trust badges">
  {% if badge_style == 'compact' %}
    <div class="trust-badges__row trust-badges__row--compact">
      <span class="trust-badge__item">✅ Free Shipping $49+</span>
      <span class="trust-badge__separator">|</span>
      <span class="trust-badge__item">🔒 Secure Checkout</span>
      <span class="trust-badge__separator">|</span>
      <span class="trust-badge__item">📦 30-Day Returns</span>
    </div>
  {% else %}
    <div class="trust-badges__grid">
      <div class="trust-badge">
        <div class="trust-badge__icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="1" y="3" width="15" height="13"></rect>
            <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
            <circle cx="5.5" cy="18.5" r="2.5"></circle>
            <circle cx="18.5" cy="18.5" r="2.5"></circle>
          </svg>
        </div>
        <div class="trust-badge__text">
          <strong>Free Shipping</strong>
          <span>On orders over $49</span>
        </div>
      </div>

      <div class="trust-badge">
        <div class="trust-badge__icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
          </svg>
        </div>
        <div class="trust-badge__text">
          <strong>Secure Checkout</strong>
          <span>SSL encrypted payment</span>
        </div>
      </div>

      <div class="trust-badge">
        <div class="trust-badge__icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 12 20 22 4 22 4 12"></polyline>
            <rect x="2" y="7" width="20" height="5"></rect>
            <line x1="12" y1="22" x2="12" y2="7"></line>
            <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path>
            <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path>
          </svg>
        </div>
        <div class="trust-badge__text">
          <strong>30-Day Returns</strong>
          <span>Hassle-free refunds</span>
        </div>
      </div>

      <div class="trust-badge">
        <div class="trust-badge__icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            <polyline points="9 12 11 14 15 10"></polyline>
          </svg>
        </div>
        <div class="trust-badge__text">
          <strong>Quality Guarantee</strong>
          <span>Vetted products only</span>
        </div>
      </div>
    </div>
  {% endif %}
</div>

<style>
  .trust-badges {
    padding: 24px 0;
    text-align: center;
  }

  .trust-badges__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    max-width: 900px;
    margin: 0 auto;
    padding: 0 16px;
  }

  .trust-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .trust-badge__icon {
    color: var(--color-foreground);
    opacity: 0.8;
  }

  .trust-badge__text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .trust-badge__text strong {
    font-size: 14px;
    font-weight: 600;
  }

  .trust-badge__text span {
    font-size: 12px;
    opacity: 0.7;
  }

  .trust-badges__row--compact {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 12px;
    font-size: 13px;
    flex-wrap: wrap;
    padding: 8px 16px;
  }

  .trust-badge__separator {
    opacity: 0.3;
  }

  @media screen and (max-width: 749px) {
    .trust-badges__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
  }
</style>
