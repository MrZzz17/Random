{% comment %}
  Featured Benefits Section — Icon-based benefits row for homepage.
  Add via Shopify Theme Editor > Add Section > Featured Benefits.
{% endcomment %}

{{ 'section-featured-benefits.css' | asset_url | stylesheet_tag }}

<div class="featured-benefits section-{{ section.id }}-padding color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="featured-benefits__heading {{ section.settings.heading_size }}">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    <div class="featured-benefits__grid featured-benefits__grid--{{ section.blocks.size }}">
      {% for block in section.blocks %}
        <div class="featured-benefit" {{ block.shopify_attributes }}>
          {% if block.settings.icon != 'none' %}
            <div class="featured-benefit__icon">
              {% case block.settings.icon %}
                {% when 'truck' %}
                  <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
                {% when 'shield' %}
                  <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                {% when 'refresh' %}
                  <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"></polyline><polyline points="1 20 1 14 7 14"></polyline><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path></svg>
                {% when 'heart' %}
                  <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                {% when 'star' %}
                  <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                {% when 'clock' %}
                  <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
              {% endcase %}
            </div>
          {% endif %}

          <div class="featured-benefit__content">
            {% if block.settings.heading != blank %}
              <h3 class="featured-benefit__title">{{ block.settings.heading }}</h3>
            {% endif %}
            {% if block.settings.text != blank %}
              <p class="featured-benefit__description">{{ block.settings.text }}</p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Featured Benefits",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Choose Us"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h2",
      "options": [
        { "value": "h2", "label": "Medium" },
        { "value": "h1", "label": "Large" },
        { "value": "h3", "label": "Small" }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "limit": 6,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "truck",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "truck", "label": "Shipping truck" },
            { "value": "shield", "label": "Shield" },
            { "value": "refresh", "label": "Returns" },
            { "value": "heart", "label": "Heart" },
            { "value": "star", "label": "Star" },
            { "value": "clock", "label": "Clock" }
          ]
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Free Shipping"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Description",
          "default": "On all orders over $49"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Benefits",
      "blocks": [
        { "type": "benefit", "settings": { "icon": "truck", "heading": "Free Shipping", "text": "On orders over $49" } },
        { "type": "benefit", "settings": { "icon": "shield", "heading": "Secure Payment", "text": "SSL encrypted checkout" } },
        { "type": "benefit", "settings": { "icon": "refresh", "heading": "Easy Returns", "text": "30-day money back guarantee" } },
        { "type": "benefit", "settings": { "icon": "heart", "heading": "Quality First", "text": "Every product is vetted" } }
      ]
    }
  ]
}
{% endschema %}
